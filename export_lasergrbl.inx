<?xml version="1.0" encoding="UTF-8"?>
<inkscape-extension xmlns="http://www.inkscape.org/namespace/inkscape/extension">
  <name>Eksportuj do LaserGRBL...</name>
  <id>net.climbers.inkscape.export_lasergrbl</id>
  <effect implements-custom-gui="true" show-stderr="true">
    <effects-menu>
      <submenu name="Export" />
    </effects-menu>
  </effect>
  <script>
    <command location="inx" interpreter="python">export_lasergrbl.py</command>
  </script>
</inkscape-extension>
